generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
  AFFILIATE_STAFF
  DRIVER
  HUB_STAFF
  DEV_ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum BagStatus {
  CREATED
  IN_TRANSIT
  AT_HUB
  PROCESSING
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum DriverAvailabilityStatus {
  OFFLINE
  AVAILABLE
  ON_TRIP
  SUSPENDED
}

enum OrderChannel {
  DOOR
  SHOP_DROP
  HYBRID
}

enum OrderEventType {
  ORDER_CREATED
  HUB_ASSIGNED
  PICKUP_SCHEDULED
  PICKED_UP
  RECEIVED_AT_HUB
  WASHING_STARTED
  DRYING_STARTED
  IRONING_STARTED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  PAYMENT_DUE
  PAID
  ISSUE_OPENED
  ISSUE_UPDATED
  ISSUE_RESOLVED
}

enum OrderIssueStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  REJECTED
}

enum OrderIssueType {
  DAMAGE
  MISSING_ITEM
  DELAY
  REFUND_REQUEST
}

enum OrderSourceType {
  DIRECT
  AFFILIATE
}

enum OrderStatusCurrent {
  CREATED
  PICKUP_SCHEDULED
  PICKED_UP
  RECEIVED_AT_HUB
  WASHING_STARTED
  DRYING_STARTED
  IRONING_STARTED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  PAYMENT_DUE
  PAID
}

enum OrderTier {
  STANDARD_48H
  EXPRESS_24H
  SAME_DAY
}

enum TripStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripStopStatus {
  PENDING
  DONE
  FAILED
  SKIPPED
}

enum TripStopType {
  PICKUP
  DROPOFF
}

enum TripType {
  PICKUP
  DELIVERY
}

enum VehicleType {
  MOTORBIKE
  CAR
  VAN
}

model Zone {
  id         String            @id @default(cuid())
  name       String            @unique
  boundaries Json
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  affiliates AffiliateShop[]
  addresses  CustomerAddress[]
  drivers    DriverProfile[]
  hubs       Hub[]
  Order      Order[]
  Trip       Trip[]
}

model Hub {
  id                   String            @id @default(cuid())
  name                 String            @unique
  zoneId               String
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  addressLabel         String
  capacityKgPerDay     Int?
  capacityOrdersPerDay Int?
  locationLat          Float?
  locationLng          Float?
  supportsTiers        Json
  zone                 Zone              @relation(fields: [zoneId], references: [id])
  HubStaffProfile      HubStaffProfile[]
  Order                Order[]
  Trip                 Trip[]
}

model CommissionPlan {
  id             String          @id
  name           String          @unique
  fixedAmountTzs Int?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  kind           String
  notes          String?
  percentageBps  Int?
  AffiliateShop  AffiliateShop[]
}

model AffiliateShop {
  id                    String                  @id @default(cuid())
  name                  String
  code                  String                  @unique
  zoneId                String
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  addressLabel          String
  commissionPlanId      String
  contactPhone          String?
  isActive              Boolean                 @default(true)
  locationLat           Float?
  locationLng           Float?
  CommissionPlan        CommissionPlan          @relation(fields: [commissionPlanId], references: [id])
  zone                  Zone                    @relation(fields: [zoneId], references: [id])
  AffiliateStaffProfile AffiliateStaffProfile[]
  orders                Order[]
}

model User {
  id                    String                 @id @default(cuid())
  email                 String?                @unique
  phone                 String                 @unique
  fullName              String
  passwordHash          String
  role                  UserRole
  status                UserStatus             @default(ACTIVE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  AffiliateStaffProfile AffiliateStaffProfile?
  CustomerAddress       CustomerAddress[]
  driverProfile         DriverProfile?
  HubStaffProfile       HubStaffProfile?
  Order                 Order[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
}

model DriverProfile {
  id                 String                   @id @default(cuid())
  userId             String                   @unique
  homeZoneId         String
  phone              String?
  vehicleType        VehicleType?
  vehiclePlate       String?
  isActive           Boolean                  @default(true)
  availabilityStatus DriverAvailabilityStatus @default(OFFLINE)
  lastStatusAt       DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  homeZone           Zone                     @relation(fields: [homeZoneId], references: [id])
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Trip               Trip[]
}

model CustomerAddress {
  id                                            String   @id @default(cuid())
  userId                                        String?
  label                                         String
  contactName                                   String?
  phone                                         String?
  addressLine1                                  String
  addressLine2                                  String?
  zoneId                                        String
  locationLat                                   Float?
  locationLng                                   Float?
  notes                                         String?
  createdAt                                     DateTime @default(now())
  updatedAt                                     DateTime @updatedAt
  User                                          User?    @relation(fields: [userId], references: [id])
  zone                                          Zone     @relation(fields: [zoneId], references: [id])
  Order_Order_dropoffAddressIdToCustomerAddress Order[]  @relation("Order_dropoffAddressIdToCustomerAddress")
  Order_Order_pickupAddressIdToCustomerAddress  Order[]  @relation("Order_pickupAddressIdToCustomerAddress")
}

model Order {
  id                                                      String             @id @default(cuid())
  orderNumber                                             String             @unique
  sourceType                                              OrderSourceType
  affiliateShopId                                         String?
  channel                                                 OrderChannel
  customerName                                            String
  customerPhone                                           String?
  notes                                                   String?
  createdAt                                               DateTime           @default(now())
  updatedAt                                               DateTime           @updatedAt
  customerUserId                                          String?
  tier                                                    OrderTier
  zoneId                                                  String
  hubId                                                   String
  pickupAddressId                                         String?
  dropoffAddressId                                        String?
  statusCurrent                                           OrderStatusCurrent
  bags                                                    Bag[]
  affiliateShop                                           AffiliateShop?     @relation(fields: [affiliateShopId], references: [id])
  User                                                    User?              @relation(fields: [customerUserId], references: [id])
  CustomerAddress_Order_dropoffAddressIdToCustomerAddress CustomerAddress?   @relation("Order_dropoffAddressIdToCustomerAddress", fields: [dropoffAddressId], references: [id])
  Hub                                                     Hub                @relation(fields: [hubId], references: [id])
  CustomerAddress_Order_pickupAddressIdToCustomerAddress  CustomerAddress?   @relation("Order_pickupAddressIdToCustomerAddress", fields: [pickupAddressId], references: [id])
  Zone                                                    Zone               @relation(fields: [zoneId], references: [id])
  events                                                  OrderEvent[]
  issues                                                  OrderIssue[]
  TripStop                                                TripStop[]
}

model Bag {
  id        String    @id @default(cuid())
  orderId   String
  tagCode   String    @unique
  bagStatus BagStatus @default(CREATED)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderEvent {
  id          String         @id @default(cuid())
  orderId     String
  eventType   OrderEventType
  occurredAt  DateTime       @default(now())
  actorUserId String?
  actorRole   String?
  notes       String?
  payloadJson Json?
  createdAt   DateTime       @default(now())
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderIssue {
  id               String           @id @default(cuid())
  orderId          String
  type             OrderIssueType
  status           OrderIssueStatus @default(OPEN)
  reportedByUserId String?
  reportedAt       DateTime         @default(now())
  description      String
  resolutionNotes  String?
  resolvedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AffiliateStaffProfile {
  id              String        @id
  userId          String        @unique
  affiliateShopId String
  jobTitle        String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  AffiliateShop   AffiliateShop @relation(fields: [affiliateShopId], references: [id])
  User            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HubStaffProfile {
  id        String   @id
  userId    String   @unique
  hubId     String
  jobTitle  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Hub       Hub      @relation(fields: [hubId], references: [id])
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id            String        @id
  type          TripType
  zoneId        String
  hubId         String?
  driverId      String
  status        TripStatus    @default(PLANNED)
  scheduledFor  DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  DriverProfile DriverProfile @relation(fields: [driverId], references: [id])
  Hub           Hub?          @relation(fields: [hubId], references: [id])
  Zone          Zone          @relation(fields: [zoneId], references: [id])
  TripStop      TripStop[]
}

model TripStop {
  id        String         @id
  tripId    String
  orderId   String
  stopType  TripStopType
  sequence  Int
  status    TripStopStatus @default(PENDING)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime
  Order     Order          @relation(fields: [orderId], references: [id])
  Trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, sequence])
}

model RefreshToken {
  id                String   @id @default(cuid())
  userId            String
  tokenHash         String   @unique
  createdAt         DateTime @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  userAgent         String?
  ipAddress         String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorRole   String?
  actionCode  String
  targetType  String
  targetId    String
  reason      String?
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?
  userAgent   String?
  occurredAt  DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([occurredAt])
}


