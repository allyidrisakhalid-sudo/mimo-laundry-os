generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
  AFFILIATE
  HUB_STAFF
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  role       UserRole
  createdAt  DateTime   @default(now())
  auditLogs  AuditLog[] @relation("AuditActor")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([createdAt])
}
