generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
  AFFILIATE_STAFF
  DRIVER
  HUB_STAFF
  DEV_ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum BagStatus {
  CREATED
  IN_TRANSIT
  AT_HUB
  PROCESSING
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum DriverAvailabilityStatus {
  OFFLINE
  AVAILABLE
  ON_TRIP
  SUSPENDED
}

enum OrderChannel {
  DOOR
  SHOP_DROP
  HYBRID
}

enum OrderEventType {
  ORDER_CREATED
  HUB_ASSIGNED
  PICKUP_SCHEDULED
  PICKED_UP
  RECEIVED_AT_HUB
  WASHING_STARTED
  DRYING_STARTED
  IRONING_STARTED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  PAYMENT_DUE
  PAID
  ISSUE_OPENED
  ISSUE_UPDATED
  ISSUE_RESOLVED
  REFUND_REQUESTED
  REFUND_ISSUED
}

enum OrderIssueStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  REJECTED
}

enum OrderIssueType {
  DAMAGE
  MISSING_ITEM
  DELAY
  REFUND_REQUEST
  REFUND_REQUESTED
}

enum OrderSourceType {
  DIRECT
  AFFILIATE
}

enum OrderStatusCurrent {
  CREATED
  PICKUP_SCHEDULED
  PICKED_UP
  RECEIVED_AT_HUB
  WASHING_STARTED
  DRYING_STARTED
  IRONING_STARTED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  PAYMENT_DUE
  PAID
}

enum OrderTier {
  STANDARD_48H
  EXPRESS_24H
  SAME_DAY
}

enum TripStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripStopStatus {
  PENDING
  DONE
  FAILED
  SKIPPED
}

enum TripStopType {
  PICKUP
  DROPOFF
}

enum TripType {
  PICKUP
  DELIVERY
}

enum VehicleType {
  MOTORBIKE
  CAR
  VAN
}

model Zone {
  id               String            @id @default(cuid())
  name             String            @unique
  boundaries       Json
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  affiliates       AffiliateShop[]
  addresses        CustomerAddress[]
  drivers          DriverProfile[]
  hubs             Hub[]
  Order            Order[]
  Trip             Trip[]
  deliveryZoneFees DeliveryZoneFee[]
}

model Hub {
  id                   String            @id @default(cuid())
  name                 String            @unique
  zoneId               String
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  addressLabel         String
  capacityKgPerDay     Int?
  capacityOrdersPerDay Int?
  locationLat          Float?
  locationLng          Float?
  supportsTiers        Json
  zone                 Zone              @relation(fields: [zoneId], references: [id])
  HubStaffProfile      HubStaffProfile[]
  Order                Order[]
  Trip                 Trip[]
}

model CommissionPlan {
  id                       String                    @id
  name                     String                    @unique
  type                     CommissionCalculationType @default(PERCENT_OF_SERVICE)
  fixedAmountTzs           Int?
  percentRate              Int?
  includeDeliveryInPercent Boolean                   @default(false)
  isActive                 Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime
  kind                     String
  notes                    String?
  percentageBps            Int?
  AffiliateShop            AffiliateShop[]
  ledgerEntries            CommissionLedgerEntry[]
}

model AffiliateShop {
  id                      String                  @id @default(cuid())
  name                    String
  code                    String                  @unique
  zoneId                  String
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  addressLabel            String
  commissionPlanId        String
  contactPhone            String?
  isActive                Boolean                 @default(true)
  locationLat             Float?
  locationLng             Float?
  CommissionPlan          CommissionPlan          @relation(fields: [commissionPlanId], references: [id])
  zone                    Zone                    @relation(fields: [zoneId], references: [id])
  AffiliateStaffProfile   AffiliateStaffProfile[]
  orders                  Order[]
  commissionLedgerEntries CommissionLedgerEntry[]
  payouts                 Payout[]
}

model User {
  id                    String                 @id @default(cuid())
  email                 String?                @unique
  phone                 String                 @unique
  fullName              String
  passwordHash          String
  role                  UserRole
  status                UserStatus             @default(ACTIVE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  AffiliateStaffProfile AffiliateStaffProfile?
  CustomerAddress       CustomerAddress[]
  driverProfile         DriverProfile?
  HubStaffProfile       HubStaffProfile?
  Order                 Order[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  paymentsReceived      Payment[]              @relation("Payment_receivedByUserId")
  paymentsCollected     Payment[]              @relation("Payment_collectedByUserId")
  paymentsReceivedAtHub Payment[]              @relation("Payment_receivedAtHubByUserId")
  paymentsVerified      Payment[]              @relation("Payment_verifiedByUserId")
  receiptsIssued        Receipt[]              @relation("Receipt_issuedByUserId")
  refundsCreated        Refund[]               @relation("Refund_createdByUserId")
  reconciliationsApproved CashReconciliation[] @relation("CashReconciliation_approvedByUserId")
  payoutsApproved       Payout[]               @relation("Payout_approvedByUserId")
  payoutsPaid           Payout[]               @relation("Payout_paidByUserId")
}

model DriverProfile {
  id                 String                   @id @default(cuid())
  userId             String                   @unique
  homeZoneId         String
  phone              String?
  vehicleType        VehicleType?
  vehiclePlate       String?
  isActive           Boolean                  @default(true)
  availabilityStatus DriverAvailabilityStatus @default(OFFLINE)
  lastStatusAt       DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  homeZone           Zone                     @relation(fields: [homeZoneId], references: [id])
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Trip               Trip[]
  cashReconciliations CashReconciliation[]
}

model CustomerAddress {
  id                                            String   @id @default(cuid())
  userId                                        String?
  label                                         String
  contactName                                   String?
  phone                                         String?
  addressLine1                                  String
  addressLine2                                  String?
  zoneId                                        String
  locationLat                                   Float?
  locationLng                                   Float?
  notes                                         String?
  createdAt                                     DateTime @default(now())
  updatedAt                                     DateTime @updatedAt
  User                                          User?    @relation(fields: [userId], references: [id])
  zone                                          Zone     @relation(fields: [zoneId], references: [id])
  Order_Order_dropoffAddressIdToCustomerAddress Order[]  @relation("Order_dropoffAddressIdToCustomerAddress")
  Order_Order_pickupAddressIdToCustomerAddress  Order[]  @relation("Order_pickupAddressIdToCustomerAddress")
}

model Order {
  id                                                      String                @id @default(cuid())
  orderNumber                                             String                @unique
  sourceType                                              OrderSourceType
  affiliateShopId                                         String?
  channel                                                 OrderChannel
  customerName                                            String
  customerPhone                                           String?
  notes                                                   String?
  createdAt                                               DateTime              @default(now())
  updatedAt                                               DateTime              @updatedAt
  customerUserId                                          String?
  tier                                                    OrderTier
  zoneId                                                  String
  hubId                                                   String
  pickupAddressId                                         String?
  dropoffAddressId                                        String?
  statusCurrent                                           OrderStatusCurrent
  bags                                                    Bag[]
  affiliateShop                                           AffiliateShop?        @relation(fields: [affiliateShopId], references: [id])
  User                                                    User?                 @relation(fields: [customerUserId], references: [id])
  CustomerAddress_Order_dropoffAddressIdToCustomerAddress CustomerAddress?      @relation("Order_dropoffAddressIdToCustomerAddress", fields: [dropoffAddressId], references: [id])
  Hub                                                     Hub                   @relation(fields: [hubId], references: [id])
  CustomerAddress_Order_pickupAddressIdToCustomerAddress  CustomerAddress?      @relation("Order_pickupAddressIdToCustomerAddress", fields: [pickupAddressId], references: [id])
  Zone                                                    Zone                  @relation(fields: [zoneId], references: [id])
  events                                                  OrderEvent[]
  issues                                                  OrderIssue[]
  deliveryOtp                                             OrderDeliveryOtp?
  TripStop                                                TripStop[]
  pricingSnapshot                                         OrderPricingSnapshot?
  lineItems                                               OrderLineItem[]
  totals                                                  OrderTotals?
  payments                                                Payment[]
  refunds                                                 Refund[]
  receipts                                                Receipt[]
  commissionLedgerEntry                                   CommissionLedgerEntry?
}

model Bag {
  id        String    @id @default(cuid())
  orderId   String
  tagCode   String    @unique
  bagStatus BagStatus @default(CREATED)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderEvent {
  id          String         @id @default(cuid())
  orderId     String
  eventType   OrderEventType
  occurredAt  DateTime       @default(now())
  actorUserId String?
  actorRole   String?
  notes       String?
  payloadJson Json?
  createdAt   DateTime       @default(now())
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderIssue {
  id               String           @id @default(cuid())
  orderId          String
  type             OrderIssueType
  status           OrderIssueStatus @default(OPEN)
  reportedByUserId String?
  reportedAt       DateTime         @default(now())
  description      String
  resolutionNotes  String?
  resolvedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AffiliateStaffProfile {
  id              String        @id
  userId          String        @unique
  affiliateShopId String
  jobTitle        String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  AffiliateShop   AffiliateShop @relation(fields: [affiliateShopId], references: [id])
  User            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HubStaffProfile {
  id        String   @id
  userId    String   @unique
  hubId     String
  jobTitle  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Hub       Hub      @relation(fields: [hubId], references: [id])
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id            String        @id
  type          TripType
  zoneId        String
  hubId         String?
  driverId      String
  status        TripStatus    @default(PLANNED)
  scheduledFor  DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  DriverProfile DriverProfile @relation(fields: [driverId], references: [id])
  Hub           Hub?          @relation(fields: [hubId], references: [id])
  Zone          Zone          @relation(fields: [zoneId], references: [id])
  TripStop      TripStop[]
}

model TripStop {
  id        String         @id
  tripId    String
  orderId   String
  stopType  TripStopType
  sequence  Int
  status    TripStopStatus @default(PENDING)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime
  Order     Order          @relation(fields: [orderId], references: [id])
  Trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, sequence])
}

model OrderDeliveryOtp {
  id        String    @id @default(cuid())
  orderId   String    @unique
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  userAgent         String?
  ipAddress         String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorRole   String?
  actionCode  String
  targetType  String
  targetId    String
  reason      String?
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?
  userAgent   String?
  occurredAt  DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([occurredAt])
}

enum PricingPlanStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum PricingServiceType {
  WASH_DRY_FOLD
  IRONING
  ADDON_SCENT
}

enum PricingItemCode {
  DUVET
  SUIT
  CURTAIN_HEAVY
}

enum OrderPricingQuoteStatus {
  ESTIMATED
  FINALIZED
}

enum CommissionCalculationType {
  FIXED_PER_ORDER
  PERCENT_OF_SERVICE
}

enum CommissionLedgerStatus {
  EARNED
  APPROVED
  PAID
  VOID
}

enum PayoutStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum PayoutMethod {
  MOBILE_MONEY
  CASH
  BANK
}

enum OrderLineItemType {
  CHARGE
  DISCOUNT
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  CARD
}

enum PaymentStatus {
  PENDING
  RECORDED
  REVERSED
}


enum CashCollectedFrom {
  CUSTOMER
  AFFILIATE
  OTHER
}

enum MobileMoneyProvider {
  MPESA
  TIGO
  AIRTEL
  HALOPESA
  OTHER
}

enum RefundMethod {
  CASH
  MOBILE_MONEY
  CREDIT
}

enum RefundStatus {
  ISSUED
  REVERSED
}

enum CashReconciliationStatus {
  OPEN
  SUBMITTED
  APPROVED
}

model PricingPlan {
  id            String            @id
  name          String
  status        PricingPlanStatus @default(DRAFT)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  channels           PricingPlanChannel[]
  kgRates            KgRate[]
  itemRates          ItemRate[]
  deliveryZoneFees   DeliveryZoneFee[]
  minimumChargeRules MinimumChargeRule[]
  pricingSnapshots   OrderPricingSnapshot[]

  @@index([status, effectiveFrom])
}

model PricingPlanChannel {
  id        String       @id
  planId    String
  channel   OrderChannel
  createdAt DateTime     @default(now())

  plan PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, channel])
  @@index([planId])
  @@index([channel])
}

model KgRate {
  id            String             @id
  planId        String
  tier          OrderTier
  serviceType   PricingServiceType
  pricePerKgTzs Int
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  plan PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, tier, serviceType])
  @@index([planId, tier])
}

model ItemRate {
  id        String          @id
  planId    String
  tier      OrderTier
  itemCode  PricingItemCode
  priceTzs  Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  plan PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, tier, itemCode])
  @@index([planId, tier])
}

model DeliveryZoneFee {
  id               String   @id
  planId           String
  zoneId           String
  doorFeeTzs       Int
  freeThresholdTzs Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  plan PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  zone Zone        @relation(fields: [zoneId], references: [id], onDelete: Restrict)

  @@unique([planId, zoneId])
  @@index([planId])
  @@index([zoneId])
}

model MinimumChargeRule {
  id         String        @id
  planId     String
  tier       OrderTier
  channel    OrderChannel?
  minimumTzs Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  plan PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, tier, channel])
  @@index([planId, tier])
}

model OrderPricingSnapshot {
  id                       String                  @id
  orderId                  String                  @unique
  pricingPlanId            String
  pricingPlanEffectiveFrom DateTime?
  quoteStatus              OrderPricingQuoteStatus
  quotedAt                 DateTime?
  finalizedAt              DateTime?
  inputsJson               Json?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pricingPlan PricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Restrict)

  @@index([pricingPlanId, quoteStatus])
}

model OrderLineItem {
  id          String            @id
  orderId     String
  type        OrderLineItemType
  description String
  quantity    Decimal           @db.Decimal(10, 2)
  unitPrice   Int
  amount      Int
  metaJson    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderTotals {
  id            String   @id
  orderId       String   @unique
  subtotal      Int
  deliveryTotal Int
  discountTotal Int
  grandTotal    Int
  balanceDue    Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id                     String              @id
  orderId                String
  method                 PaymentMethod
  amountTzs              Int
  reference              String?
  receivedByUserId       String?
  receivedAt             DateTime            @default(now())
  status                 PaymentStatus       @default(RECORDED)
  collectedByUserId      String?
  collectedAt            DateTime?
  collectedFrom          CashCollectedFrom?
  receivedAtHubByUserId  String?
  receivedAtHubAt        DateTime?
  cashBatchId            String?
  provider               MobileMoneyProvider?
  providerTxnId          String?
  rawCallbackJson        Json?
  verifiedAt             DateTime?
  verifiedByUserId       String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  order                  Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  receivedBy             User?               @relation("Payment_receivedByUserId", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  collectedBy            User?               @relation("Payment_collectedByUserId", fields: [collectedByUserId], references: [id], onDelete: SetNull)
  receivedAtHubBy        User?               @relation("Payment_receivedAtHubByUserId", fields: [receivedAtHubByUserId], references: [id], onDelete: SetNull)
  verifiedBy             User?               @relation("Payment_verifiedByUserId", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  receipts               Receipt[]
  refunds                Refund[]

  @@index([orderId, receivedAt])
  @@index([status])
  @@index([method, receivedAt])
}

model CommissionLedgerEntry {
  id                String                    @id @default(cuid())
  affiliateShopId   String
  orderId           String                    @unique
  planId            String
  calculationType   CommissionCalculationType
  baseAmountTzs     Int?
  rate              Int?
  amountTzs         Int
  status            CommissionLedgerStatus    @default(EARNED)
  earnedAt          DateTime                  @default(now())
  approvedAt        DateTime?
  paidAt            DateTime?
  payoutId          String?
  createdAt         DateTime                  @default(now())

  affiliateShop     AffiliateShop             @relation(fields: [affiliateShopId], references: [id], onDelete: Cascade)
  order             Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  plan              CommissionPlan            @relation(fields: [planId], references: [id], onDelete: Restrict)
  payout            Payout?                   @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([affiliateShopId, status, earnedAt])
  @@index([payoutId])
  @@index([planId])
}

model Payout {
  id                String          @id @default(cuid())
  affiliateShopId   String
  periodStart       DateTime
  periodEnd         DateTime
  totalAmountTzs    Int
  status            PayoutStatus    @default(DRAFT)
  approvedByUserId  String?
  approvedAt        DateTime?
  paidByUserId      String?
  paidAt            DateTime?
  paymentMethod     PayoutMethod?
  paymentReference  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  affiliateShop     AffiliateShop   @relation(fields: [affiliateShopId], references: [id], onDelete: Cascade)
  approvedBy        User?           @relation("Payout_approvedByUserId", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  paidBy            User?           @relation("Payout_paidByUserId", fields: [paidByUserId], references: [id], onDelete: SetNull)
  ledgerEntries     CommissionLedgerEntry[]

  @@index([affiliateShopId, periodStart, periodEnd])
  @@index([status])
}
model Receipt {
  id             String   @id
  receiptNumber  String   @unique
  orderId        String
  paymentId      String   @unique
  amountTzs      Int
  reference      String
  issuedAt       DateTime @default(now())
  issuedByUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  issuedBy User?    @relation("Receipt_issuedByUserId", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId, issuedAt])
}


model Refund {
  id              String       @id
  orderId         String
  paymentId       String?
  amountTzs       Int
  method          RefundMethod
  reference       String?
  reason          String
  createdByUserId String
  createdAt       DateTime     @default(now())
  status          RefundStatus @default(ISSUED)

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment    Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdBy  User     @relation("Refund_createdByUserId", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
  @@index([status])
}

model CustomerCreditLedger {
  id             String   @id
  customerUserId String
  orderId        String?
  amountTzs      Int
  reason         String
  createdAt      DateTime @default(now())

  @@index([customerUserId, createdAt])
  @@index([orderId, createdAt])
}

model CashReconciliation {
  id                String                   @id
  driverId          String
  date              String
  expectedCashTzs   Int
  declaredCashTzs   Int?
  differenceTzs     Int?
  status            CashReconciliationStatus @default(OPEN)
  submittedAt       DateTime?
  approvedAt        DateTime?
  approvedByUserId  String?

  driver            DriverProfile            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  approvedBy        User?                    @relation("CashReconciliation_approvedByUserId", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([driverId, date])
  @@index([date, status])
}


enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}


enum JournalSourceType {
  INVOICE
  PAYMENT
  REFUND
  COMMISSION
  PAYOUT
  ADJUSTMENT
}
model Account {
  id        String      @id
  code      String      @unique
  name      String
  type      AccountType
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  journalLines JournalLine[]

  @@index([type, isActive])
}




model JournalEntry {
  id              String            @id
  entryNumber     String            @unique
  description     String
  sourceType      JournalSourceType
  sourceId        String
  occurredAt      DateTime
  createdByUserId String?
  createdAt       DateTime          @default(now())
  lines           JournalLine[]

  @@unique([sourceType, sourceId])
  @@index([occurredAt])
}

model JournalLine {
  id             String       @id
  journalEntryId String
  accountId      String
  debitTzs       Int          @default(0)
  creditTzs      Int          @default(0)
  memo           String?
  createdAt      DateTime     @default(now())

  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
}
