generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  HUB_STAFF
  AFFILIATE_STAFF
  DRIVER
  CUSTOMER
}

enum VehicleType {
  MOTORBIKE
  CAR
  VAN
}

enum DriverAvailabilityStatus {
  OFFLINE
  AVAILABLE
  ON_TRIP
  SUSPENDED
}

enum TripType {
  PICKUP
  DELIVERY
}

enum TripStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripStopType {
  PICKUP
  DROPOFF
}

enum TripStopStatus {
  PENDING
  DONE
  FAILED
  SKIPPED
}

enum OrderSourceType {
  DIRECT
  AFFILIATE
}

enum OrderChannel {
  DOOR
  SHOP_DROP
  HYBRID
}

model Zone {
  id              String           @id @default(uuid())
  name            String           @unique
  boundaries      Json
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  hubs            Hub[]
  affiliateShops  AffiliateShop[]
  orders          Order[]
  driverProfiles  DriverProfile[]
  trips           Trip[]
}

model User {
  id                    String                @id @default(uuid())
  email                 String                @unique
  fullName              String
  role                  UserRole
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  hubStaffProfile       HubStaffProfile?
  affiliateStaffProfile AffiliateStaffProfile?
  driverProfile         DriverProfile?
}

model Hub {
  id                   String           @id @default(uuid())
  name                 String           @unique
  zoneId               String
  addressLabel         String
  locationLat          Float?
  locationLng          Float?
  capacityKgPerDay     Int?
  capacityOrdersPerDay Int?
  supportsTiers        Json
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  zone                 Zone             @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  staffProfiles        HubStaffProfile[]
  trips                Trip[]
}

model HubStaffProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  hubId     String
  jobTitle  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hub       Hub      @relation(fields: [hubId], references: [id], onDelete: Restrict)
}

model CommissionPlan {
  id                String          @id @default(uuid())
  name              String          @unique
  kind              String
  fixedAmountTzs    Int?
  percentageBps     Int?
  notes             String?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  affiliateShops    AffiliateShop[]
}

model AffiliateShop {
  id               String                  @id @default(uuid())
  code             String                  @unique
  name             String
  zoneId           String
  commissionPlanId String
  addressLabel     String
  locationLat      Float?
  locationLng      Float?
  contactPhone     String?
  isActive         Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  zone             Zone                    @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  commissionPlan   CommissionPlan          @relation(fields: [commissionPlanId], references: [id], onDelete: Restrict)
  staffProfiles    AffiliateStaffProfile[]
  orders           Order[]
}

model AffiliateStaffProfile {
  id              String         @id @default(uuid())
  userId          String         @unique
  affiliateShopId String
  jobTitle        String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliateShop   AffiliateShop  @relation(fields: [affiliateShopId], references: [id], onDelete: Restrict)
}

model DriverProfile {
  id                 String                     @id @default(uuid())
  userId             String                     @unique
  homeZoneId         String
  phone              String?
  vehicleType        VehicleType?
  vehiclePlate       String?
  isActive           Boolean                    @default(true)
  availabilityStatus DriverAvailabilityStatus   @default(OFFLINE)
  lastStatusAt       DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeZone           Zone                       @relation(fields: [homeZoneId], references: [id], onDelete: Restrict)
  trips              Trip[]
}

model Trip {
  id           String      @id @default(uuid())
  type         TripType
  zoneId       String
  hubId        String?
  driverId     String
  status       TripStatus  @default(PLANNED)
  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  zone         Zone        @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  hub          Hub?        @relation(fields: [hubId], references: [id], onDelete: SetNull)
  driver       DriverProfile @relation(fields: [driverId], references: [id], onDelete: Restrict)
  stops        TripStop[]
}

model TripStop {
  id         String         @id @default(uuid())
  tripId     String
  orderId    String
  stopType   TripStopType
  sequence   Int
  status     TripStopStatus @default(PENDING)
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  trip       Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([tripId, sequence])
}

model Order {
  id              String           @id @default(uuid())
  orderNumber     String           @unique
  sourceType      OrderSourceType
  affiliateShopId String?
  channel         OrderChannel
  orderZoneId     String
  customerName    String
  customerPhone   String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  affiliateShop   AffiliateShop?   @relation(fields: [affiliateShopId], references: [id], onDelete: SetNull)
  orderZone       Zone             @relation(fields: [orderZoneId], references: [id], onDelete: Restrict)
  tripStops       TripStop[]
}

