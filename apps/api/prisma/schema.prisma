generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
  AFFILIATE_STAFF
  DRIVER
  HUB_STAFF
}

model Zone {
  id         String            @id @default(uuid())
  name       String            @unique
  boundaries Json?
  metadata   Json?
  hubs       Hub[]
  shops      AffiliateShop[]
  drivers    Driver[]
  addresses  CustomerAddress[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model Hub {
  id                   String            @id @default(uuid())
  name                 String            @unique
  zoneId               String
  addressLabel         String
  locationLat          Decimal?          @db.Decimal(10, 7)
  locationLng          Decimal?          @db.Decimal(10, 7)
  capacityKgPerDay     Int?
  capacityOrdersPerDay Int?
  supportsTiers        Json
  isActive             Boolean           @default(true)
  zone                 Zone              @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  staffProfiles        HubStaffProfile[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([zoneId])
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  fullName        String
  role            UserRole
  passwordHash    String?
  isActive        Boolean          @default(true)
  hubStaffProfile HubStaffProfile?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model HubStaffProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  hubId     String
  jobTitle  String?
  isActive  Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hub       Hub      @relation(fields: [hubId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hubId])
}

model AffiliateShop {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
}

model Driver {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
}

model CustomerAddress {
  id           String   @id @default(uuid())
  customerName String
  addressLine  String
  zoneId       String
  zone         Zone     @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([zoneId])
}
