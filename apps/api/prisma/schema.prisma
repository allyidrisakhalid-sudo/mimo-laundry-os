generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
  AFFILIATE_STAFF
  DRIVER
  HUB_STAFF
}

enum CommissionPlanType {
  FIXED_PER_ORDER
  PERCENT_OF_SERVICE
}

enum CommissionAppliesTo {
  SHOP_ONLY
  ALL_CHANNELS
}

enum OrderSourceType {
  DIRECT
  AFFILIATE
}

enum OrderChannel {
  DOOR
  SHOP_DROP
  HYBRID
}

model Zone {
  id         String            @id @default(uuid())
  name       String            @unique
  boundaries Json?
  metadata   Json?
  hubs       Hub[]
  shops      AffiliateShop[]
  drivers    Driver[]
  addresses  CustomerAddress[]
  orders     Order[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model Hub {
  id                   String            @id @default(uuid())
  name                 String            @unique
  zoneId               String
  addressLabel         String
  locationLat          Decimal?          @db.Decimal(10, 7)
  locationLng          Decimal?          @db.Decimal(10, 7)
  capacityKgPerDay     Int?
  capacityOrdersPerDay Int?
  supportsTiers        Json
  isActive             Boolean           @default(true)
  zone                 Zone              @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  staffProfiles        HubStaffProfile[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([zoneId])
}

model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  fullName               String
  role                   UserRole
  passwordHash           String?
  isActive               Boolean                @default(true)
  hubStaffProfile        HubStaffProfile?
  affiliateStaffProfile  AffiliateStaffProfile?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

model HubStaffProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  hubId     String
  jobTitle  String?
  isActive  Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hub       Hub      @relation(fields: [hubId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hubId])
}

model CommissionPlan {
  id              String               @id @default(uuid())
  name            String               @unique
  type            CommissionPlanType
  fixedAmountTzs  Int?
  percentRate     Decimal?             @db.Decimal(5, 2)
  appliesTo       CommissionAppliesTo  @default(SHOP_ONLY)
  isActive        Boolean              @default(true)
  shops           AffiliateShop[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model AffiliateShop {
  id                String                  @id @default(uuid())
  code              String                  @unique
  name              String
  zoneId            String
  commissionPlanId  String?
  addressLabel      String?
  locationLat       Decimal?                @db.Decimal(10, 7)
  locationLng       Decimal?                @db.Decimal(10, 7)
  contactPhone      String?
  isActive          Boolean                 @default(true)
  zone              Zone                    @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  commissionPlan    CommissionPlan?         @relation(fields: [commissionPlanId], references: [id], onDelete: Restrict)
  staffProfiles     AffiliateStaffProfile[]
  orders            Order[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([zoneId])
  @@index([commissionPlanId])
}

model AffiliateStaffProfile {
  id              String         @id @default(uuid())
  userId          String         @unique
  affiliateShopId String
  jobTitle        String?
  isActive        Boolean        @default(true)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliateShop   AffiliateShop  @relation(fields: [affiliateShopId], references: [id], onDelete: Restrict)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([affiliateShopId])
}

model Driver {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
}

model CustomerAddress {
  id           String   @id @default(uuid())
  customerName String
  addressLine  String
  zoneId       String
  zone         Zone     @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([zoneId])
}

model Order {
  id              String          @id @default(uuid())
  orderNumber     String          @unique
  sourceType      OrderSourceType
  affiliateShopId String?
  channel         OrderChannel
  orderZoneId     String
  customerName    String
  customerPhone   String?
  notes           String?
  affiliateShop   AffiliateShop?  @relation(fields: [affiliateShopId], references: [id], onDelete: Restrict)
  orderZone       Zone            @relation(fields: [orderZoneId], references: [id], onDelete: Restrict)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([affiliateShopId])
  @@index([orderZoneId])
  @@index([sourceType])
  @@index([channel])
}
