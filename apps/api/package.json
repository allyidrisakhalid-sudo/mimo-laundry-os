{
  "name": "@mimo/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx ./src/dev.ts",
    "build": "node -e \"console.log('api build ok')\"",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx,.mjs,.cjs --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma": "prisma",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.18.0",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
