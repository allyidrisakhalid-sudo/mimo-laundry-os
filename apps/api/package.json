{
  "name": "@mimo/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node ./src/dev.js",
    "build": "node -e \"console.log('api build ok')\"",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx,.mjs,.cjs --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma": "prisma",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "prisma": "^7.4.2",
    "tsx": "^4.21.0"
  }
}
